{
  "name": "soundmaster-admin-dashboard",
  "version": "1.0.0",
  "description": "Admin Dashboard for Soundmaster Radio Website",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "types:check": "tsc --noEmit",
    "build": "webpack --mode production",
    "start": "webpack serve --mode development",
    "build:worker": "wrangler build",
    "dev:worker": "wrangler dev",
    "build:all": "node build.js",
    "deploy:all": "node build.js --deploy",
    "test:api": "node test/test-api.js"
  },
  "dependencies": {
    "@tsndr/cloudflare-worker-jwt": "^2.4.2",
    "itty-cors": "^0.3.6",
    "itty-router": "^4.0.23",
    "react-router-dom": "^7.12.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240208.0",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.3",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.3",
    "mini-css-extract-plugin": "^2.9.2",
    "ts-loader": "^9.5.2",
    "typescript": "^5.3.3",
    "webpack": "^5.99.8",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.1",
    "wrangler": "^4.14.4"
  },
  "type": "module"
}
